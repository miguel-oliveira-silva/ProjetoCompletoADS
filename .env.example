# =============================================================================
# .env.example — Variáveis de ambiente para o docker-compose.yml
# =============================================================================
# Copie este arquivo para ".env" (mesmo diretório do docker-compose.yml) e
# ajuste os valores. O arquivo ".env" NÃO deve ir para o Git (veja .gitignore)
# pois conterá senhas reais.
#
#   cp .env.example .env
# =============================================================================

# Credenciais do PostgreSQL (usadas pelos 4 microsserviços)
DB_USER=markovitz
DB_PASSWORD=troque_esta_senha_em_producao

# Credenciais do RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=troque_esta_senha_em_producao

# Taxa livre de risco usada no cálculo de Sharpe (portfolio-service)
RISK_FREE_RATE=0.1075
